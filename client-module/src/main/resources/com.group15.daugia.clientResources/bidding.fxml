<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12" prefWidth="860" prefHeight="520"
      xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.group15.daugia.client.controller.BiddingController"
      styleClass="bidding-root"
      stylesheets="@css/menu.css">
    <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
    </padding>

    <!-- ===== INFO PANEL ===== -->
    <VBox styleClass="bidding-info-panel" spacing="10">
        <!-- Hàng tiêu đề + nút back -->
        <HBox alignment="CENTER_LEFT" spacing="12">
            <Button text="← Quay lại" onAction="#handleBack" styleClass="btn-back"/>
            <Label fx:id="lblProductTitle" text="Đang tải..." styleClass="bidding-product-title"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblStatusBadge" text="..." styleClass="badge-scheduled"/>
        </HBox>

        <!-- Hàng thông tin chi tiết -->
        <HBox spacing="40" alignment="CENTER_LEFT">
            <!-- Người bán -->
            <VBox spacing="3">
                <Label text="Người bán" styleClass="bidding-info-key"/>
                <Label fx:id="lblSeller" text="—" styleClass="bidding-info-val"/>
            </VBox>

            <!-- Giá khởi điểm -->
            <VBox spacing="3">
                <Label text="Giá khởi điểm" styleClass="bidding-info-key"/>
                <Label fx:id="lblStartPrice" text="—" styleClass="bidding-info-val"/>
            </VBox>

            <!-- Người đang dẫn đầu -->
            <VBox spacing="3">
                <Label text="Người dẫn đầu" styleClass="bidding-info-key"/>
                <Label fx:id="lblLeader" text="—" styleClass="bidding-info-val"/>
            </VBox>

            <Pane HBox.hgrow="ALWAYS"/>

            <!-- Giá hiện tại (highlight) -->
            <VBox spacing="2" alignment="CENTER_RIGHT">
                <Label text="Giá hiện tại" styleClass="bidding-info-key"/>
                <Label fx:id="lblCurPrice" text="0 ₫" styleClass="bidding-price-current"/>
            </VBox>

            <!-- Đếm ngược -->
            <VBox spacing="2" alignment="CENTER_RIGHT">
                <Label text="Còn lại" styleClass="bidding-info-key"/>
                <Label fx:id="lblCountdown" text="--:--:--" styleClass="bidding-countdown"/>
            </VBox>
        </HBox>
    </VBox>

    <!-- ===== ACTION PANEL ===== -->
    <VBox fx:id="actionPanel" styleClass="bidding-action-panel" spacing="10">
        <!-- Hàng đặt giá thủ công -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Giá của bạn:" styleClass="bidding-info-key"/>
            <TextField fx:id="txtBidAmount" promptText="Nhập số tiền..." styleClass="bidding-input"/>
            <Button fx:id="btnPlaceBid" text="Đặt giá" onAction="#handlePlaceBid"
                    styleClass="btn-place-bid"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <!-- Nút tự động đấu giá -->
            <Button fx:id="btnAutoBid" text="🤖  Tự động đấu giá"
                    onAction="#handleToggleAutoBid" styleClass="btn-auto-bid"/>
        </HBox>

        <!-- Panel nhập maxAmount cho auto-bid (ẩn mặc định) -->
        <HBox fx:id="autoBidPanel" spacing="10" alignment="CENTER_LEFT"
              styleClass="auto-bid-panel" managed="false" visible="false">
            <Label text="Giá tối đa:" styleClass="auto-bid-label"/>
            <TextField fx:id="txtMaxAmount" promptText="Giá tối đa bạn chấp nhận..."
                       styleClass="bidding-input"/>
            <Label text="Bước giá tối thiểu:" styleClass="auto-bid-label"/>
            <TextField fx:id="txtBidStep" promptText="Mặc định: 1.0"
                       styleClass="bidding-input" prefWidth="140"/>
            <Button text="Xác nhận" onAction="#handleConfirmAutoBid"
                    style="-fx-background-color: #1e88e5; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-padding: 8 18; -fx-background-radius: 7;
                           -fx-cursor: hand;"/>
            <Button text="Hủy" onAction="#handleCancelAutoBid"
                    styleClass="btn-back"/>
        </HBox>
    </VBox>

    <!-- ===== HISTORY PANEL ===== -->
    <TitledPane text="Biểu đồ giá realtime" expanded="true" animated="false" styleClass="bidding-chart-pane">
        <content>
            <LineChart fx:id="priceChart" prefHeight="210" createSymbols="false" legendVisible="true" styleClass="bidding-chart">
                <xAxis>
                    <CategoryAxis label="Thời gian"/>
                </xAxis>
                <yAxis>
                    <NumberAxis label="Giá"/>
                </yAxis>
            </LineChart>
        </content>
    </TitledPane>

    <VBox styleClass="bidding-history-panel" spacing="8" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" spacing="8">
            <Label text="Lịch sử đấu giá" styleClass="bidding-history-title"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblHistoryCount" text="" styleClass="section-subtitle"/>
        </HBox>
        <ListView fx:id="bidHistoryList" VBox.vgrow="ALWAYS"
                  style="-fx-background-color: transparent; -fx-border-color: transparent;"/>
    </VBox>
</VBox>
