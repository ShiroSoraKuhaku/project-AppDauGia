<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="14" prefWidth="1180" prefHeight="760"
      xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.group15.daugia.client.controller.MenuSellerController"
      styleClass="seller-root"
      stylesheets="@css/menu.css">
    <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #dfe4ea; -fx-border-radius: 12; -fx-padding: 14 18;">
        <VBox spacing="2">
            <Label text="Màn hình bán" styleClass="section-title"/>
            <Label fx:id="lblSubtitle" text="Đang tải..." styleClass="section-subtitle"/>
        </VBox>
        <Pane HBox.hgrow="ALWAYS"/>
        <Button text="Làm mới" onAction="#handleRefresh" styleClass="menu-button-secondary"/>
    </HBox>

    <SplitPane dividerPositions="0.6" VBox.vgrow="ALWAYS" styleClass="seller-split-pane">
        <VBox spacing="12" styleClass="seller-panel">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="Sản phẩm đang bán" styleClass="seller-panel-title"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Label text="Chọn thẻ để xem hoặc xóa" styleClass="seller-panel-subtitle"/>
            </HBox>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-background: transparent;">
                <padding>
                    <Insets top="2" right="2" bottom="2" left="2"/>
                </padding>
                <FlowPane fx:id="cardPane" hgap="14" vgap="14" prefWrapLength="720"/>
            </ScrollPane>
        </VBox>

        <ScrollPane fitToWidth="true" fitToHeight="false" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox spacing="12" styleClass="seller-panel">
                <Label text="Thông tin đăng bán" styleClass="seller-panel-title"/>
                <Label text="Chọn ngày, giờ bắt đầu và kết thúc phiên đấu giá." styleClass="seller-panel-subtitle"/>

                <VBox spacing="6">
                    <Label text="Tên sản phẩm" styleClass="seller-field-label"/>
                    <TextField fx:id="txtName" styleClass="bidding-input"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Mô tả" styleClass="seller-field-label"/>
                    <TextField fx:id="txtDesc" styleClass="bidding-input"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Giá sàn" styleClass="seller-field-label"/>
                    <TextField fx:id="txtPrice" styleClass="bidding-input"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Thời gian bắt đầu" styleClass="seller-field-label"/>
                    <DatePicker fx:id="dpStartDate" maxWidth="Infinity"/>
                    <GridPane hgap="8" maxWidth="Infinity">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50"/>
                            <ColumnConstraints percentWidth="50"/>
                        </columnConstraints>
                        <ComboBox fx:id="cbStartHour" promptText="Giờ" maxWidth="Infinity"/>
                        <ComboBox fx:id="cbStartMinute" promptText="Phút" maxWidth="Infinity" GridPane.columnIndex="1"/>
                    </GridPane>
                </VBox>

                <VBox spacing="6">
                    <Label text="Thời gian kết thúc" styleClass="seller-field-label"/>
                    <DatePicker fx:id="dpEndDate" maxWidth="Infinity"/>
                    <GridPane hgap="8" maxWidth="Infinity">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50"/>
                            <ColumnConstraints percentWidth="50"/>
                        </columnConstraints>
                        <ComboBox fx:id="cbEndHour" promptText="Giờ" maxWidth="Infinity"/>
                        <ComboBox fx:id="cbEndMinute" promptText="Phút" maxWidth="Infinity" GridPane.columnIndex="1"/>
                    </GridPane>
                </VBox>

                <VBox spacing="8">
                    <Label text="Mở nhanh" styleClass="seller-field-label"/>
                    <HBox spacing="8">
                        <TextField fx:id="txtQuickStartAfter" promptText="Mở sau (phút)" styleClass="bidding-input"/>
                        <TextField fx:id="txtQuickDuration" promptText="Kéo dài (phút)" styleClass="bidding-input"/>
                        <Button text="Áp dụng" onAction="#handleApplyQuickTime" styleClass="menu-button-secondary"/>
                    </HBox>
                    <Label text="Có thể dùng mở nhanh hoặc tự chọn ngày, giờ ở trên." styleClass="seller-hint"/>
                </VBox>

                <HBox spacing="10">
                    <Button text="Đăng bán" onAction="#handleAddProduct" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                            styleClass="seller-button-primary"/>
                    <Button text="Xóa" onAction="#handleDeleteProduct" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                            styleClass="seller-button-danger"/>
                </HBox>

                <Button text="Làm trống form" onAction="#handleClearForm" maxWidth="Infinity"
                        styleClass="menu-button-secondary"/>
            </VBox>
        </ScrollPane>
    </SplitPane>
</VBox>
