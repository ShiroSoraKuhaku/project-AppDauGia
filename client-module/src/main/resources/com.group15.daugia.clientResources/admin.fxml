<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12" prefWidth="860" prefHeight="520"
      xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.group15.daugia.client.controller.AdminController"
      styleClass="admin-root"
      stylesheets="@css/menu.css">
    <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
    </padding>

    <Label text="Bảng quản trị" styleClass="section-title"/>

    <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS" styleClass="admin-tab-pane">
        <tabs>
            <Tab text="Quản lý người dùng">
                <VBox spacing="10" styleClass="admin-card">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <HBox spacing="8">
                        <Button text="Cấm người dùng" onAction="#handleBanUser" styleClass="admin-action-button-danger"/>
                        <Button text="Làm mới" onAction="#refreshUsers" styleClass="admin-action-button"/>
                        <Pane HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <TableView fx:id="tblUsers" VBox.vgrow="ALWAYS" styleClass="admin-table">
                        <columns>
                            <TableColumn fx:id="colUsername" text="Username" prefWidth="180"/>
                            <TableColumn fx:id="colRole" text="Role" prefWidth="120"/>
                            <TableColumn fx:id="colBanned" text="Bị cấm" prefWidth="120"/>
                            <TableColumn fx:id="colBalance" text="Số dư" prefWidth="220"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>
            <Tab text="Quản lý phiên đấu giá">
                <VBox spacing="10" styleClass="admin-card">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <HBox spacing="8">
                        <Button text="Mở ngay" onAction="#handleOpenAuction" styleClass="admin-action-button"/>
                        <Button text="Đóng ngay" onAction="#handleCloseAuction" styleClass="admin-action-button"/>
                        <Button text="Hủy" onAction="#handleCancelAuction" styleClass="admin-action-button-danger"/>
                        <Button text="Làm mới" onAction="#refreshAuctions" styleClass="admin-action-button"/>
                        <Pane HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <TableView fx:id="tblAuctions" VBox.vgrow="ALWAYS" styleClass="admin-table">
                        <columns>
                            <TableColumn fx:id="colAuctionId" text="ID" prefWidth="70"/>
                            <TableColumn fx:id="colTitle" text="Tiêu đề" prefWidth="220"/>
                            <TableColumn fx:id="colStatus" text="Trạng thái" prefWidth="110"/>
                            <TableColumn fx:id="colCurPrice" text="Giá hiện tại" prefWidth="150"/>
                            <TableColumn fx:id="colStartTime" text="Bắt đầu" prefWidth="170"/>
                            <TableColumn fx:id="colEndTime" text="Kết thúc" prefWidth="170"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>
        </tabs>
    </TabPane>
</VBox>
