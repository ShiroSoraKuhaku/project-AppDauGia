<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="contentRoot" prefHeight="560.0" prefWidth="860.0" styleClass="menu-root"
            stylesheets="@css/menu.css"
            xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.group15.daugia.client.controller.DashboardController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: white; -fx-border-color: #dfe4ea; -fx-border-width: 0 0 1 0;">
            <padding>
                <Insets top="12.0" right="16.0" bottom="12.0" left="16.0"/>
            </padding>
            <Label text="Đấu giá" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2f3542;"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Button fx:id="bidderButton" mnemonicParsing="false" onAction="#showBidder" text="Đấu giá" styleClass="menu-button-secondary"/>
            <Button fx:id="sellerButton" mnemonicParsing="false" onAction="#showSeller" text="Bán" styleClass="menu-button-secondary"/>
            <Button fx:id="adminButton" mnemonicParsing="false" onAction="#showAdmin" text="Quản trị" styleClass="menu-button"/>
            <Button mnemonicParsing="false" onAction="#logout" text="Đăng xuất" styleClass="menu-button-secondary"/>
        </HBox>
    </top>
</BorderPane>
